<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Medication Highlights</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="stylesheet" href="/styles.css" />
</head>

<body>
  <main class="app-shell">
    <header class="topbar">
      <div>
        <p class="eyebrow">Apple Health Medications</p>
        <h1 id="page-title">Highlights</h1>
      </div>
      <div class="selectors" aria-label="Medication filters">
        <label>
          <span>User</span>
          <select id="user-select"></select>
        </label>
        <label>
          <span>Medication</span>
          <select id="medication-select"></select>
        </label>
      </div>
    </header>

    <section class="status-panel" id="status-panel" role="status">Loading medication history...</section>

    <section class="phone-frame" id="medication-view" hidden>
      <nav class="ios-nav" aria-label="Mock medication detail navigation">
        <span class="back-link">‹ Medications</span>
        <strong id="nav-title"></strong>
        <span></span>
      </nav>

      <h2>Highlights</h2>
      <article class="highlight-card">
        <div class="med-label">
          <span class="pill-icon" aria-hidden="true">
            <span></span>
            <span></span>
          </span>
          <span id="highlight-name"></span>
        </div>
        <p class="headline" id="highlight-copy"></p>
        <div class="calendar-controls" aria-label="Calendar navigation">
          <button type="button" id="calendar-previous" aria-label="Show previous 28 days">‹</button>
          <p id="calendar-hover-summary" aria-live="polite"></p>
          <button type="button" id="calendar-next" aria-label="Show next 28 days">›</button>
        </div>
        <div class="weekday-row" aria-hidden="true">
          <span>Sun</span>
          <span>Mon</span>
          <span>Tue</span>
          <span>Wed</span>
          <span>Thu</span>
          <span>Fri</span>
          <span>Sat</span>
        </div>
        <div class="calendar-grid" id="calendar-grid" aria-label="Last 28 days medication log"></div>
        <p class="range-copy" id="range-copy"></p>
      </article>

      <section class="selected-day-section" id="selected-day-section" hidden>
        <h2 id="selected-day-title"></h2>
        <ul class="selected-day-list" id="selected-day-list"></ul>
      </section>

      <div class="section-heading">
        <h2>Details</h2>
        <button type="button" id="refresh-button">Refresh</button>
      </div>
      <article class="details-card">
        <div class="tablet-art" aria-hidden="true">
          <span></span>
        </div>
        <div>
          <h3 id="detail-name"></h3>
          <p id="detail-form">Tablet</p>
          <p id="detail-dose"></p>
        </div>
      </article>

      <h2 class="about-heading">About</h2>
    </section>
  </main>

  <script src="/app.js" type="module"></script>
</body>

</html>